<% content_for :title, "タグ管理" %>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
  <h1 style="font-size:24px;font-weight:bold;color:#1e293b;">タグ管理</h1>
  <%= link_to "＋ 新規タグ", new_tag_path, style: "background:#6366f1;color:white;padding:8px 16px;border-radius:6px;text-decoration:none;font-size:14px;" %>
</div>

<% if @tags.empty? %>
  <div style="text-align:center;padding:48px;color:#94a3b8;">
    <p>タグがありません</p>
    <%= link_to "最初のタグを作成する", new_tag_path, style: "color:#6366f1;" %>
  </div>
<% else %>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;">
    <% @tags.each do |tag| %>
      <div style="background:white;border:1px solid #e2e8f0;border-radius:8px;padding:16px;display:flex;align-items:center;gap:12px;">
        <div style="width:36px;height:36px;border-radius:50%;background:<%= tag.color %>;flex-shrink:0;"></div>
        <div style="flex:1;min-width:0;">
          <div style="font-weight:600;color:#1e293b;"><%= tag.name %></div>
          <div style="font-size:12px;color:#94a3b8;"><%= tag.tasks.count %> タスク</div>
        </div>
        <div style="display:flex;gap:8px;">
          <%= link_to "編集", edit_tag_path(tag), style: "color:#6366f1;font-size:13px;text-decoration:none;" %>
          <%= button_to "削除", tag_path(tag), method: :delete,
            data: { turbo_confirm: "削除しますか？関連付けも解除されます。" },
            style: "background:none;border:none;color:#ef4444;font-size:13px;cursor:pointer;padding:0;" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
